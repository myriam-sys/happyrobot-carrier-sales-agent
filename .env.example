# FMCSA Query Central API key
FMCSA_API_KEY=

# Secret key used to authenticate inbound requests via X-API-Key header
API_KEY=

# SQLite database path (relative to project root)
DATABASE_URL=sqlite:///./data/carrier_sales.db

# HTTP proxy for FMCSA requests (use a US proxy to bypass geo-restriction)
# Format: http://username:password@ip:port
FMCSA_PROXY=